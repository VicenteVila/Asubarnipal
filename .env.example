# =============================================
# Asubarnipal - Environment Variables Template
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# =============================================
# TELEGRAM BOT (Required)
# =============================================
# Get your token from @BotFather on Telegram
TELEGRAM_TOKEN=your_bot_token_here

# =============================================
# OLLAMA - Local LLM (Required)
# =============================================
# Install Ollama: https://ollama.ai
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b

# OCR model for PDF/image text extraction
# Pull with: ollama pull glm-ocr:latest
OCR_MODEL=glm-ocr:latest

# =============================================
# GOOGLE GEMINI - Cloud LLM Fallback (Optional)
# =============================================
# Get keys: https://ai.google.dev
# Comma-separated for multiple keys (rotation)
GEMINI_KEYS=

# =============================================
# BRAVE SEARCH - Web Research (Optional)
# =============================================
# Get key: https://brave.com/search/api
# Monthly limit: 1500 requests (free tier)
BRAVE_API_KEY=

# =============================================
# HUGGING FACE - Model Downloads (Optional)
# =============================================
# Get token: https://huggingface.co/settings/tokens
HF_TOKEN=

# =============================================
# RAG - Vector Search Engine
# =============================================
RAG_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
RAG_DEVICE=cpu

# =============================================
# OBSIDIAN - External Vault (Optional)
# =============================================
# Windows: C:\Obsidian
# Linux/WSL: /mnt/c/Obsidian
OBSIDIAN_PATH=

# =============================================
# BACKGROUND RITUALS
# =============================================
ENABLE_HEARTBEAT=true
# HEARTBEAT_INTERVAL=60     # seconds
# SUTURE_INTERVAL=600       # seconds (10 min)
# GRAPH_INTERVAL=1800       # seconds (30 min)

# =============================================
# TURBOQUANT - LLM Optimization
# =============================================
TURBOQUANT_ENABLED=true
TURBOQUANT_DEFAULT_MODE=consultor
TURBOQUANT_AUTO_DETECT=true

# =============================================
# DEFAULT MODEL SELECTION
# =============================================
# Options: ollama, gemini, auto
DEFAULT_MODEL=auto
